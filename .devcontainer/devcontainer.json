{
  "name": "AI Photo Reviewer Dev Env",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces",
  // 👇 新增：将 VS Code 设置持久化到容器中
  "customizations": {
    "vscode": {
      "settings": {
        "http.proxy": "http://host.docker.internal:7897",
        "https.proxy": "http://host.docker.internal:7897",
        "http.proxyStrictSSL": false
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "expo.vscode-expo-tools",
        "openai.chatgpt",
        "yzhang.markdown-all-in-one",
        "GitHub.copilot-chat"
      ]
    }
  },
  "remoteEnv": {
    "HTTP_PROXY": "http://host.docker.internal:7897",
    "HTTPS_PROXY": "http://host.docker.internal:7897",
    "NO_PROXY": "localhost,127.0.0.1"
  },
  "remoteUser": "node",
  // 使用单行 shell 命令，确保由 /bin/sh 解析并顺序执行
  "postCreateCommand": "git config --global user.name 'LGJ' && git config --global user.email '1752104296@qq.com' && git config --global --add safe.directory ${containerWorkspaceFolder} && (git lfs install --system || true) && (git lfs install --local --force || true)",
  "features": {}
}